<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"> <!-- Soft Off-White Background -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavLayout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 1. HEADER SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <!-- Avatar -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cvDashAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/ivDashAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera" />
                </androidx.cardview.widget.CardView>

                <!-- Name & Welcome -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toRightOf="@id/cvDashAvatar"
                    android:layout_toLeftOf="@+id/rlNotification"
                    android:layout_marginLeft="16dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textColor="#0F172A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahul Kumar"
                        android:textColor="#0047FF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashLibName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome to Krishna Library"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <!-- Badges Row (Exact Match) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <!-- Green Approved Badge -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#DCFCE7"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            android:layout_marginRight="8dp">
                            <TextView
                                android:id="@+id/tvStatusBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ Approved • Active"
                                android:textColor="#10B981"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingLeft="10dp"
                                android:paddingRight="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </androidx.cardview.widget.CardView>

                        <!-- Blue Seat Badge -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#EFF6FF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:id="@+id/tvSeatBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Seat A12"
                                android:textColor="#3B82F6"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingLeft="10dp"
                                android:paddingRight="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Notification Bell with Red Dot -->
                <RelativeLayout
                    android:id="@+id/rlNotification"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_centerInParent="true"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:tint="#0F172A"/>
                    <!-- Red Dot -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginTop="4dp"
                        android:layout_marginRight="4dp"
                        app:cardBackgroundColor="#EF4444"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="3"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
            </RelativeLayout>

            <!-- 2. THE 2x2 GRID SECTION -->
            
            <!-- ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">
                
                <!-- ATTENDANCE CARD (White bg, Green Accents) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <!-- Top Row: Icon + Title + Arrow -->
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <!-- Circular Light Green Icon Bg -->
                            <androidx.cardview.widget.CardView android:id="@+id/iconAtt" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#DCFCE7" app:cardCornerRadius="18dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_today" android:tint="#10B981"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/iconAtt" android:layout_marginLeft="10dp" android:layout_centerVertical="true" android:text="Today Attendance" android:textColor="#10B981" android:textSize="11sp" android:textStyle="bold"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:src="@android:drawable/ic_media_next" android:tint="#0F172A"/>
                        </RelativeLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not Marked" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan QR to mark\nyour attendance" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        
                        <!-- Light Green Button -->
                        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginTop="16dp" app:cardBackgroundColor="#F0FDF4" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_camera" android:tint="#10B981" android:layout_marginRight="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan Now" android:textColor="#10B981" android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- FEE STATUS CARD (White bg, Orange Accents) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView android:id="@+id/iconFee" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#FEF3C7" app:cardCornerRadius="18dp" app:cardElevation="0dp">
                                <!-- Replaced emoji with a standard text symbol inside the image spot for Rupees, since there is no default Rupee drawable -->
                                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="₹" android:textColor="#F59E0B" android:textSize="20sp" android:textStyle="bold" android:gravity="center"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/iconFee" android:layout_marginLeft="10dp" android:layout_centerVertical="true" android:text="Fee Status" android:textColor="#F59E0B" android:textSize="11sp" android:textStyle="bold"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:src="@android:drawable/ic_media_next" android:tint="#0F172A"/>
                        </RelativeLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Due" android:textColor="#EF4444" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Due Amount\n₹ 1,200" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        
                        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginTop="16dp" app:cardBackgroundColor="#FFFBEB" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_view" android:tint="#F59E0B" android:layout_marginRight="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View UPI QR" android:textColor="#F59E0B" android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp">
                
                <!-- SEAT INFO CARD (White bg, Blue Accents) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView android:id="@+id/iconSeat" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#DBEAFE" app:cardCornerRadius="18dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#3B82F6"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/iconSeat" android:layout_marginLeft="10dp" android:layout_centerVertical="true" android:text="Seat Information" android:textColor="#3B82F6" android:textSize="11sp" android:textStyle="bold"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:src="@android:drawable/ic_media_next" android:tint="#0F172A"/>
                        </RelativeLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A12" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Block A • Row 2\n" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        
                        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginTop="16dp" app:cardBackgroundColor="#EFF6FF" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="Your Seat is Confirmed" android:textColor="#3B82F6" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- NOTICE CARD (White bg, Purple Accents) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView android:id="@+id/iconNotice" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#F3E8FF" app:cardCornerRadius="18dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_info_details" android:tint="#A855F7"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/iconNotice" android:layout_marginLeft="10dp" android:layout_centerVertical="true" android:text="Latest Notice" android:textColor="#A855F7" android:textSize="11sp" android:textStyle="bold"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:src="@android:drawable/ic_media_next" android:tint="#0F172A"/>
                        </RelativeLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1 New Notice" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Important updates\nfrom library" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        
                        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginTop="16dp" app:cardBackgroundColor="#FAF5FF" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="View Notices" android:textColor="#A855F7" android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- 3. BIG BLUE SCAN BANNER -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0047FF"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="30dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_camera" android:tint="#FFFFFF" android:layout_marginRight="16dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan Attendance" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan QR at the entrance to mark attendance" android:textColor="#E0E7FF" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" android:tint="#FFFFFF"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            
            <View android:layout_width="match_parent" android:layout_height="80dp"/> <!-- Bottom padding for nav bar -->
        </LinearLayout>
    </ScrollView>

    <!-- 4. BOTTOM NAVIGATION & FLOATING SCAN BUTTON -->
    <RelativeLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true">

        <!-- White Navigation Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_alignParentBottom="true"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="10dp"
            app:cardCornerRadius="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingTop="8dp">
                
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_view" android:tint="#0047FF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="#0047FF" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" android:tint="#64748B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attend" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Empty space for Floating Button -->
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" android:tint="#64748B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fees" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" android:tint="#64748B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#64748B" android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Floating Blue Circular Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            app:cardBackgroundColor="#0047FF"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp">
            
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#FFFFFF"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"/>
        </androidx.cardview.widget.CardView>

    </RelativeLayout>
</RelativeLayout>